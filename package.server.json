{
  "name": "@timkame/server",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude 'tests/integration/**'",
    "test:integration": "doppler run -- vitest run tests/integration/"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.7.6",
    "@supabase/supabase-js": "^2.103.3",
    "@timkame/db": "*",
    "@timkame/shared": "*",
    "hono": "^4.7.0",
    "openai": "^6.34.0",
    "ws": "^8.20.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.17.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0"
  }
}
